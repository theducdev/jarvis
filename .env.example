# Jarvis Demo — Environment Variables Template
# Copy this file to `.env` and fill in your keys.
# DO NOT commit the real `.env` file.

# === API Keys ===
# Gemini: https://aistudio.google.com/app/apikey (free tier: 60 req/min)
GEMINI_API_KEY=your_gemini_key_here

# ElevenLabs: https://elevenlabs.io (free tier: 10k chars/month)
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_turbo_v2_5
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY=0.75

# === Clap Wake Detector ===
CLAP_THRESHOLD=0.5
CLAP_COOLDOWN_SEC=2.0
CLAP_DOUBLE_WINDOW_MIN_MS=200
CLAP_DOUBLE_WINDOW_MAX_MS=800
CLAP_MIC_DEVICE_INDEX=

# === Backend ===
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# === Frontend ===
FRONTEND_PORT=5173
